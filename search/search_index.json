{"config":{"lang":["en"],"separator":"[\\s\\u200b\\u3000\\-\u3001\u3002\uff0c\uff0e\uff1f\uff01\uff1b]+","pipeline":["stemmer"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"Welcome to Deep Skills Wiki","text":"<p>\u8fd9\u662f\u4e00\u4e2a\u81f4\u529b\u4e8e\u6df1\u5ea6\u6280\u672f\u601d\u8003\u3001\u5de5\u7a0b\u5b9e\u8df5\u4e0e\u4e2a\u4eba\u6210\u957f\u7684\u77e5\u8bc6\u5e93\u3002</p>"},{"location":"#_1","title":"\u4e3b\u8981\u5185\u5bb9","text":"<ul> <li>\u6280\u672f\u535a\u5ba2: \u5206\u4eab\u65e5\u5e38\u5f00\u53d1\u4e2d\u7684\u6df1\u5ea6\u63a2\u7d22\u4e0e\u603b\u7ed3\u3002</li> <li>\u77e5\u8bc6\u56fe\u8c31: \u6574\u7406\u5404\u9886\u57df\u7684\u5e95\u5c42\u903b\u8f91\u4e0e\u6838\u5fc3\u6280\u80fd\u3002</li> <li>\u5de5\u7a0b\u5b9e\u8df5: \u8bb0\u5f55\u89e3\u51b3\u590d\u6742\u95ee\u9898\u7684\u8fc7\u7a0b\u4e0e\u65b9\u6848\u3002</li> </ul>"},{"location":"#_2","title":"\u5feb\u901f\u5bfc\u822a","text":"<ul> <li>\u9605\u8bfb\u6700\u65b0\u535a\u6587</li> </ul>"},{"location":"about/","title":"\u5173\u4e8e\u6211","text":"<p>\u4f60\u597d\uff01\u6211\u662f xp-55\u3002</p> <p>\u6211\u662f\u4e00\u540d\u70ed\u8877\u4e8e\u63a2\u7d22\u6280\u672f\u6df1\u5ea6\u7684\u5f00\u53d1\u8005\u3002\u8fd9\u4e2a\u7f51\u7ad9\uff08Deep Skills Wiki\uff09\u662f\u6211\u8bb0\u5f55\u5b66\u4e60\u5fc3\u5f97\u3001\u6280\u672f\u6c89\u6dc0\u548c\u5de5\u7a0b\u5b9e\u8df5\u7684\u4e2a\u4eba\u7a7a\u95f4\u3002</p>"},{"location":"about/#_2","title":"\u5173\u6ce8\u9886\u57df","text":"<ul> <li>\u540e\u7aef\u5f00\u53d1: \u6df1\u5165\u7814\u7a76\u9ad8\u6027\u80fd\u3001\u9ad8\u53ef\u7528\u7684\u7cfb\u7edf\u67b6\u6784\u3002</li> <li>AI \u8f85\u52a9\u7f16\u7a0b: \u63a2\u7d22\u5982\u4f55\u5229\u7528\u5927\u8bed\u8a00\u6a21\u578b\u63d0\u5347\u5f00\u53d1\u6548\u7387\u3002</li> <li>\u5e95\u5c42\u539f\u7406: \u5bf9\u64cd\u4f5c\u7cfb\u7edf\u3001\u7f51\u7edc\u534f\u8bae\u548c\u6570\u636e\u5e93\u5185\u6838\u4fdd\u6301\u6301\u7eed\u7684\u597d\u5947\u5fc3\u3002</li> </ul>"},{"location":"about/#_3","title":"\u6280\u80fd\u6808","text":"<ul> <li>\u7f16\u7a0b\u8bed\u8a00: Python, Go, Rust, JavaScript</li> <li>\u5de5\u5177/\u6846\u67b6: Docker, Kubernetes, MkDocs, Astro</li> <li>\u5176\u4ed6: \u81ea\u52a8\u5316\u90e8\u7f72 (CI/CD), \u7cfb\u7edf\u8c03\u4f18</li> </ul>"},{"location":"about/#_4","title":"\u8054\u7cfb\u65b9\u5f0f","text":"<ul> <li>GitHub: xp-55</li> <li>Email: your-email@example.com</li> </ul>"},{"location":"links/","title":"\u53cb\u94fe","text":"<p>\u5728\u8fd9\u91cc\u5206\u4eab\u6211\u5e38\u53bb\u7684\u6280\u672f\u535a\u5ba2\u3001\u8d44\u6e90\u7f51\u7ad9\u548c\u670b\u53cb\u4eec\u7684\u4e2a\u4eba\u4e3b\u9875\u3002</p>"},{"location":"links/#_2","title":"\ud83c\udf10 \u63a8\u8350\u535a\u5ba2","text":"<ul> <li>[Example Blog Name]: \u63cf\u8ff0\u8fd9\u4e2a\u535a\u5ba2\u7684\u4e3b\u8981\u5185\u5bb9\u3002</li> <li>[Example Tech Blog]: \u63cf\u8ff0\u8fd9\u4e2a\u535a\u5ba2\u7684\u4e3b\u8981\u5185\u5bb9\u3002</li> </ul>"},{"location":"links/#_3","title":"\ud83d\udcda \u8d44\u6e90\u7f51\u7ad9","text":"<ul> <li>[MkDocs Material Documentation]: \u5f3a\u5927\u7684\u9759\u6001\u7ad9\u70b9\u751f\u6210\u5668\u6587\u6863\u3002</li> <li>[Astro Docs]: \u6784\u5efa\u9ad8\u6027\u80fd\u73b0\u4ee3 Web \u5e94\u7528\u7684\u5229\u5668\u3002</li> </ul>"},{"location":"links/#_4","title":"\ud83d\udca1 \u5176\u4ed6","text":"<ul> <li>[GitHub Explore]: \u53d1\u73b0\u65b0\u7684\u5f00\u6e90\u9879\u76ee\u3002</li> <li>[Hacker News]: \u6700\u524d\u6cbf\u7684\u6280\u672f\u65b0\u95fb\u793e\u533a\u3002</li> </ul> <p>\u5982\u679c\u60a8\u4e5f\u60f3\u52a0\u5165\u672c\u7ad9\u7684\u53cb\u94fe\uff0c\u6b22\u8fce\u901a\u8fc7 Email \u8054\u7cfb\u6211\uff01</p>"},{"location":"projects/","title":"\u6211\u7684\u9879\u76ee","text":"<p>\u8fd9\u91cc\u5c55\u793a\u4e86\u6211\u53c2\u4e0e\u6216\u7ef4\u62a4\u7684\u4e00\u4e9b\u5f00\u6e90\u9879\u76ee\u3002</p>"},{"location":"projects/#_2","title":"\ud83c\udf1f \u6838\u5fc3\u9879\u76ee","text":""},{"location":"projects/#deep-skills-wiki","title":"Deep Skills Wiki","text":"<p>\u672c\u535a\u5ba2\u7684\u6e90\u4ee3\u7801\uff0c\u57fa\u4e8e MkDocs Material \u6784\u5efa\uff0c\u96c6\u6210\u4e86\u535a\u5ba2\u63d2\u4ef6\u548c\u81ea\u52a8\u5316\u90e8\u7f72\u6d41\u7a0b\u3002</p> <ul> <li>\u6280\u672f\u6808: MkDocs, Python, GitHub Actions</li> <li>\u7279\u70b9: \u6781\u81f4\u7684\u9605\u8bfb\u4f53\u9a8c\uff0c\u81ea\u52a8\u751f\u6210\u535a\u6587\u5217\u8868\u3002</li> </ul>"},{"location":"projects/#_3","title":"\ud83d\udee0\ufe0f \u5176\u4ed6\u5de5\u5177","text":""},{"location":"projects/#example-project-1","title":"[Example Project 1]","text":"<p>\u7b80\u77ed\u63cf\u8ff0\u4f60\u7684\u9879\u76ee\u529f\u80fd\u548c\u4eae\u70b9\u3002</p> <ul> <li>\u6280\u672f\u6808: Rust, WebAssembly</li> <li>\u72b6\u6001: \u7ef4\u62a4\u4e2d</li> </ul>"},{"location":"projects/#example-project-2","title":"[Example Project 2]","text":"<p>\u4e00\u4e2a\u81ea\u52a8\u5316\u7684\u811a\u672c\u5de5\u5177\uff0c\u7528\u4e8e\u89e3\u51b3\u7279\u5b9a\u7684\u5de5\u7a0b\u95ee\u9898\u3002</p> <ul> <li>\u6280\u672f\u6808: Python, Docker</li> <li>\u72b6\u6001: \u5df2\u5f52\u6863</li> </ul>"},{"location":"blog/","title":"\u6280\u672f\u535a\u5ba2","text":"<p>\u8fd9\u91cc\u8bb0\u5f55\u4e86\u6211\u5bf9\u6280\u672f\u7684\u6df1\u5ea6\u601d\u8003\u4e0e\u5b9e\u8df5\u603b\u7ed3\u3002</p>"},{"location":"blog/2026/03/08/%E6%AC%A2%E8%BF%8E%E6%9D%A5%E5%88%B0%E6%88%91%E7%9A%84%E6%8A%80%E6%9C%AF%E5%8D%9A%E5%AE%A2/","title":"\u6b22\u8fce\u6765\u5230\u6211\u7684\u6280\u672f\u535a\u5ba2","text":"<p>\u8fd9\u662f\u6211\u7684\u7b2c\u4e00\u7bc7\u535a\u6587\u3002\u6211\u5c06\u5728\u8fd9\u91cc\u5206\u4eab\u5173\u4e8e\u6df1\u5ea6\u5b66\u4e60\u3001\u8f6f\u4ef6\u5de5\u7a0b\u4ee5\u53ca\u4e2a\u4eba\u6210\u957f\u7684\u601d\u8003\u3002</p>"},{"location":"blog/2026/03/08/%E6%AC%A2%E8%BF%8E%E6%9D%A5%E5%88%B0%E6%88%91%E7%9A%84%E6%8A%80%E6%9C%AF%E5%8D%9A%E5%AE%A2/#_2","title":"\u4e3a\u4ec0\u4e48\u5efa\u7acb\u8fd9\u4e2a\u535a\u5ba2\uff1f","text":"<p>\u5728\u8fd9\u4e2a\u4fe1\u606f\u7206\u70b8\u7684\u65f6\u4ee3\uff0c\u788e\u7247\u5316\u7684\u77e5\u8bc6\u968f\u5904\u53ef\u89c1\uff0c\u4f46\u6df1\u5ea6\u7684\u601d\u8003\u5374\u8d8a\u6765\u8d8a\u7a00\u7f3a\u3002\u6211\u5e0c\u671b\u901a\u8fc7\u6587\u5b57\u5c06\u8fd9\u4e9b\u788e\u7247\u5316\u7684\u7ecf\u9a8c\u7cfb\u7edf\u5316\uff0c\u5e76\u4e0e\u66f4\u591a\u4eba\u4ea4\u6d41\u3002</p>"},{"location":"blog/2026/03/08/%E6%AC%A2%E8%BF%8E%E6%9D%A5%E5%88%B0%E6%88%91%E7%9A%84%E6%8A%80%E6%9C%AF%E5%8D%9A%E5%AE%A2/#_3","title":"\u63a5\u4e0b\u6765\u7684\u8ba1\u5212","text":"<ul> <li>\u6df1\u5165\u89e3\u6790\u5927\u578b\u9879\u76ee\u7684\u67b6\u6784\u8bbe\u8ba1\u3002</li> <li>\u63a2\u7d22 AI \u9a71\u52a8\u7684\u8f6f\u4ef6\u5f00\u53d1\u65b0\u8303\u5f0f\u3002</li> <li>\u8bb0\u5f55\u4e2a\u4eba\u6280\u672f\u6808\u7684\u6f14\u8fdb\u8fc7\u7a0b\u3002</li> </ul> <p>\u611f\u8c22\u4f60\u7684\u5173\u6ce8\uff01</p>"},{"location":"blog/archive/2026/","title":"2026","text":""},{"location":"blog/category/technical/","title":"Technical","text":""},{"location":"blog/category/blog/","title":"Blog","text":""}]}